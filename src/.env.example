# Copy to .env and fill in your values
SECRET_KEY=change-me-to-a-random-string
HOST=0.0.0.0
PORT=8080
DEBUG=1

# YOLOv8
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.4

# Twilio SMS (optional -- alerts log locally without these)
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
ALERT_PHONES=+1XXXXXXXXXX,+1YYYYYYYYYY
ALERT_COOLDOWN=60
